{% extends 'base_front.html.twig' %}

{% block title %}{{ 'support.title'|trans }}{% endblock %}

{% block description %}{{ 'support.description'|trans }}{% endblock %}

{% block canonical %}{{ absolute_url(path('support')) }}{% endblock %}

{% block content %}

    <div class="one-page support-page row parallax">
        <div class="offset-md-1 col-md-10 offset-lg-2 col-lg-8 offset-xl-3 col-xl-6">
            <div class="content">
                <h1>{{ 'nav.support_us'|trans }}</h1>

                <p>
                    Vous aimez COJOB Nantes et vous voulez nous soutenir ? Merci d’avance !
                </p>
                <p>
                    Voici en quelques mots ce que vous pouvez faire…
                </p>
                <ul>
                    <li>
                        Vous pouvez adhérer à l’association ! <a href="#join-form">C’est par là</a>
                    </li>
                    <li>
                        Vous pouvez faire un don ! <a href="#donate-form" onclick="gtag('event', 'Donate Link support', {'event_category': 'Button Click'});">C’est par ici</a>
                    </li>
                    <li>
                        Vous êtes une entreprise, une association ou autre ? Vous pouvez devenir partenaire en proposant
                        un atelier ou une collaboration. <a href="{{ path('contact') }}">Contactez-nous !</a>
                    </li>
                </ul>
                <p>
                    Surtout, parlez de nous autour de vous !
                </p>
            </div>
        </div>
        <div class="offset-md-1 col-md-10 offset-lg-2 col-lg-8 offset-xl-3 col-xl-6" id="join-form">
            <div class="join-form-div">
                <h2>{{ 'support.join'|trans }}</h2>
                <iframe id="haWidget" allowtransparency="true" 
                        src="https://www.helloasso.com/associations/cojob-nantes/adhesions/adhesion-2026/widget"
                        style="width:100%;height:750px;border:none;" onload="window.scroll(0, this.offsetTop)"></iframe>
                <div style="width:100%;text-align:center;">Merci à <a href="https://www.helloasso.com" rel="nofollow">HelloAsso</a>
                </div>
            </div>
        </div>
		<div class="offset-md-1 col-md-10 offset-lg-2 col-lg-8 offset-xl-3 col-xl-6" id="donate-form">
            <div class="join-form-div">
                <h2>{{ 'support.donate'|trans }}</h2>
                <iframe id="haWidget" allowtransparency="true" scrolling="auto"
                        src="https://www.helloasso.com/associations/cojob-nantes/formulaires/4/widget"
                        style="width:100%;height:750px;border:none;"></iframe>
                <div style="width:100%;text-align:center;">Merci à <a href="https://www.helloasso.com" rel="nofollow">HelloAsso</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
